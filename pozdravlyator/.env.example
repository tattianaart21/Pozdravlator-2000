# Бенчи: клиент Trace Service (только /bench, /bench_task; /trace не используется)
# Прямой URL — нужен CORS на бэкенде.
# VITE_BENCH_API_URL=https://trace-api.example.com

# Локально без CORS: цель прокси (см. vite.config) и URL через префикс.
# VITE_BENCH_API_PROXY_TARGET=http://127.0.0.1:8000
# VITE_BENCH_API_URL=/bench-service

# Сопоставление pipeline → вкладки «Sbervoyager» / «Бизнес»
# VITE_BENCH_PIPELINE_SBER=e2e,sbervoyager,Sbervoyager
# VITE_BENCH_PIPELINE_BIZ=business,biz,samokat

# Ссылка «Админка трейсов» на карточке (вне этого API).
# VITE_TRACE_ADMIN_BASE_URL=https://admin.example/traces
